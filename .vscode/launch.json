{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "C++: Debug Active File",
      "type": "cppdbg",
      "request": "launch",
      "args": [],
      "stopAtEntry": false,
      "externalConsole": false,
      "cwd": "${workspaceFolder}",
      "program": "${workspaceFolder}/.vscode/bin/${fileBasenameNoExtension}",
      "preLaunchTask": "C++: Build Active File",
      "MIMode": "gdb",
      "miDebuggerPath": "/usr/bin/gdb",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
